# IsMyEmailSpam.com — Environment Variables
# Copy this to .env and fill in your values

# Domain for test email addresses
MAIL_DOMAIN=ismyemailspam.com

# Upstash Redis (get from https://upstash.com → your database → REST API tab)
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your-token-here

# Cloudflare Email Worker (any random secret — must match Worker env variable)
CLOUDFLARE_WORKER_SECRET=your-random-secret-here

# SpamAssassin (Docker sidecar)
# Use "spamassassin" when running with docker-compose (default)
# Use "localhost" when running Python directly without Docker
SPAMASSASSIN_HOST=spamassassin
SPAMASSASSIN_PORT=783

# Frontend URL (for CORS — change to your production URL in prod)
FRONTEND_URL=http://localhost:3000

# AI Email Writer — Groq API key (FREE)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Contact Form — SMTP Configuration
# For Gmail: Use smtp.gmail.com:587 with App Password (not regular password)
# For SendGrid: Use smtp.sendgrid.net:587 with API key as password
# For Mailgun: Use smtp.mailgun.org:587 with credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
CONTACT_EMAIL=contact@checkemaildelivery.com
